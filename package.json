{
  "name": "techassassin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:client",
    "dev:web": "npm run dev:client",
    "dev:api": "npm run dev:backend",
    "dev:client": "npm run dev --prefix apps/web",
    "dev:backend": "npm run dev --prefix backend",
    "build": "npm run build:client && npm run build:backend",
    "build:web": "npm run build:client",
    "build:api": "npm run build:backend",
    "build:client": "npm run build --prefix apps/web",
    "build:backend": "npm run build --prefix backend",
    "typecheck:client": "npm run typecheck --prefix apps/web",
    "typecheck:backend": "npm run typecheck --prefix backend",
    "typecheck": "npm run typecheck:client && npm run typecheck:backend",
    "test:client": "npm test --prefix apps/web",
    "test:backend": "npm test --prefix backend",
    "test": "npm run test:client && npm run test:backend"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
