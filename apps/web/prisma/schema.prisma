datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Profile {
  id                   String                 @id
  memberId             String?                @unique @map("member_id")
  username             String                 @unique
  fullName             String?                @map("full_name")
  email                String?                @unique
  phone                String?
  avatarUrl            String?                @map("avatar_url")
  bio                  String?
  githubUrl            String?                @map("github_url")
  linkedinUrl          String?                @map("linkedin_url")
  portfolioUrl         String?                @map("portfolio_url")
  bannerUrl            String?                @map("banner_url")
  readme               String?
  address              String?
  firstName            String?                @map("first_name")
  lastName             String?                @map("last_name")
  gender               String?
  tshirtSize           String?                @map("tshirt_size")
  dietaryPreference    String?                @map("dietary_preference")
  allergies            String?
  hasEducation         Boolean                @default(true) @map("has_education")
  education            String?
  university           String?
  degreeType           String?                @map("degree_type")
  graduationYear       Int?                   @map("graduation_year")
  graduationMonth      String?                @map("graduation_month")
  skills               String[]               @default([])
  interests            String[]               @default([])
  roles                String[]               @default([])
  resumeUrl            String?                @map("resume_url")
  hasExperience        Boolean                @default(false) @map("has_experience")
  emergencyContactName String?                @map("emergency_contact_name")
  emergencyContactPhone String?               @map("emergency_contact_phone")
  isEmailPublic        Boolean                @default(false) @map("is_email_public")
  isPhonePublic        Boolean                @default(false) @map("is_phone_public")
  isAddressPublic      Boolean                @default(false) @map("is_address_public")
  isAdmin              Boolean                @default(false) @map("is_admin")
  totalXp              Int                    @default(0) @map("total_xp")
  usernameChangeCount  Int                    @default(0) @map("username_change_count")
  lastUsernameChange   DateTime?              @map("last_username_change") @db.Timestamptz
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  registrations         Registration[]
  leaderboardEntries    Leaderboard[]
  announcements         Announcement[]
  collaborationRequests CollaborationRequest[]
  notifications         Notification[]
  userSkills            UserSkill[]

  @@map("profiles")
}

model Skill {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String      @unique
  category  String      @default("Programming")
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz
  userSkills UserSkill[]

  @@map("skills")
}

model UserSkill {
  userId           String    @map("user_id")
  skillId          String    @map("skill_id") @db.Uuid
  proficiencyLevel Int       @default(1) @map("proficiency_level")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@map("user_skills")
}

model Event {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title            String
  description      String?
  startDate        DateTime       @map("start_date") @db.Timestamptz
  endDate          DateTime       @map("end_date") @db.Timestamptz
  location         String
  maxParticipants  Int            @default(100) @map("max_participants")
  registrationOpen Boolean        @default(true) @map("registration_open")
  imageUrls        String[]       @default([]) @map("image_urls")
  prizes           Json           @default("{}")
  themes           String[]       @default([])
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  registrations    Registration[]
  leaderboardEntries Leaderboard[]

  @@map("events")
}

model Registration {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id")
  eventId     String    @map("event_id") @db.Uuid
  teamName    String    @map("team_name")
  projectIdea String?   @map("project_idea")
  status      String    @default("pending")
  checkedInAt DateTime? @map("checked_in_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("registrations")
}

model Leaderboard {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  eventId   String   @map("event_id") @db.Uuid
  score     Int      @default(0)
  rank      Int      @default(0)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("leaderboard")
}

model Announcement {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId  String   @map("author_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  author Profile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

model Resource {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  contentUrl  String?  @map("content_url")
  category    String   @default("Documentation")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("resources")
}

model Sponsor {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  logoUrl    String?  @map("logo_url")
  websiteUrl String?  @map("website_url")
  tier       String   @default("bronze")
  description String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("sponsors")
}

model CollaborationRequest {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String?  @map("user_id")
  organizationName       String   @map("organization_name")
  organizationType       String   @map("organization_type")
  contactName            String   @map("contact_name")
  roleTitle              String?  @map("role_title")
  workEmail              String   @map("work_email")
  phone                  String?
  websiteUrl             String?  @map("website_url")
  collaborationInterests String[] @default([]) @map("collaboration_interests")
  budgetRange            String?  @map("budget_range")
  timeline               String?
  studentAudience        String?  @map("student_audience")
  message                String
  status                 String   @default("new")
  sourcePage             String   @default("collaborate") @map("source_page")
  metadata               Json     @default("{}")
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  profile Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("collaboration_requests")
}

model Notification {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id")
  type      String
  title     String
  content   String?
  message   String?
  metadata  Json      @default("{}")
  actionUrl String?   @map("action_url")
  isRead    Boolean   @default(false) @map("is_read")
  read      Boolean   @default(false)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
